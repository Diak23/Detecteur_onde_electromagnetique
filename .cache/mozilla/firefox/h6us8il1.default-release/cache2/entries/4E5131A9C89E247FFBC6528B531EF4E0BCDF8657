class IBeaconEventApp:
    def __init__(self, root: tk.Tk) -> None:
        self.root = root
        self.root.title("Analyse iBeacon V2 - Evenements regroupes")
        self.root.geometry("1450x900")
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        self.output_dir = OUTPUT_ROOT / f"acquisition_{timestamp}"
        self.capture = BLECapture(TARGET_MAC, self.output_dir)
        self.frames: list[BLEFrame] = []
        self.events: list[AdvertisingEvent] = []
        self.running = False
        self.export_done = False
        self._build_ui()
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)
        self.root.after(REFRESH_MS, self.update_ui)

    def _build_ui(self) -> None:
        top = ttk.Frame(self.root, padding=8)
        top.pack(fill="x")
        ttk.Label(top, text="Analyse iBeacon - Evenements 37/38/39", font=("TkDefaultFont", 16, "bold")).pack(side="left", padx=(0, 20))
        self.start_button = ttk.Button(top, text="Demarrer", command=self.start_capture)
        self.start_button.pack(side="left", padx=5)
        self.stop_button = ttk.Button(top, text="Arreter et sauvegarder", command=self.stop_capture, state="disabled")
        self.stop_button.pack(side="left", padx=5)
        ttk.Button(top, text="Exporter rapport", command=self.export_report).pack(side="left", padx=5)
        self.status_label = ttk.Label(top, text="Etat : arrete")
        self.status_label.pack(side="left", padx=20)

        stats_frame = ttk.LabelFrame(self.root, text="Statistiques en temps reel", padding=8)
        stats_frame.pack(fill="x", padx=8, pady=(0, 8))
        self.stat_vars = {
            "events": tk.StringVar(value="Evenements : 0"), "frames": tk.StringVar(value="Trames : 0"),
            "rssi": tk.StringVar(value="RSSI moyen : -- dBm"), "interval": tk.StringVar(value="Intervalle : -- ms"),
            "complete": tk.StringVar(value="Complets : -- %"), "loss": tk.StringVar(value="Perte evenements : -- %"),
            "packet_loss": tk.StringVar(value="Perte canaux : -- %"),
        }
        for variable in self.stat_vars.values():
            ttk.Label(stats_frame, textvariable=variable, font=("TkDefaultFont", 10, "bold")).pack(side="left", padx=12)

        notebook = ttk.Notebook(self.root)
        notebook.pack(fill="both", expand=True, padx=8, pady=8)
        self.tab_live, self.tab_intervals, self.tab_distribution, self.tab_table = [ttk.Frame(notebook) for _ in range(4)]
        notebook.add(self.tab_live, text="RSSI et durees")
        notebook.add(self.tab_intervals, text="Intervalles et pertes")
        notebook.add(self.tab_distribution, text="Histogramme et canaux")
        notebook.add(self.tab_table, text="Evenements regroupes")
        self._build_live_tab(); self._build_intervals_tab(); self._build_distribution_tab(); self._build_table_tab()

    def _build_live_tab(self) -> None:
        self.live_fig = Figure(figsize=(11, 7), dpi=100)
        self.ax_rssi = self.live_fig.add_subplot(211)
        self.ax_duration = self.live_fig.add_subplot(212)
        self.live_canvas = FigureCanvasTkAgg(self.live_fig, master=self.tab_live)
        self.live_canvas.get_tk_widget().pack(fill="both", expand=True)

    def _build_intervals_tab(self) -> None:
        self.interval_fig = Figure(figsize=(11, 7), dpi=100)
        self.ax_interval = self.interval_fig.add_subplot(211)
        self.ax_loss = self.interval_fig.add_subplot(212)
        self.interval_canvas = FigureCanvasTkAgg(self.interval_fig, master=self.tab_intervals)
        self.interval_canvas.get_tk_widget().pack(fill="both", expand=True)

    def _build_distribution_tab(self) -> None:
        self.distribution_fig = Figure(figsize=(11, 7), dpi=100)
        self.ax_hist = self.distribution_fig.add_subplot(211)
        self.ax_channels = self.distribution_fig.add_subplot(212)
        self.distribution_canvas = FigureCanvasTkAgg(self.distribution_fig, master=self.tab_distribution)
        self.distribution_canvas.get_tk_widget().pack(fill="both", expand=True)

    def _build_table_tab(self) -> None:
        columns = ("event", "time", "interval", "frames", "channels", "missing", "rssi", "frame_duration", "event_span")
        self.tree = ttk.Treeview(self.tab_table, columns=columns, show="headings")
        headings = {
            "event": "Evenement", "time": "Temps (s)", "interval": "Intervalle (ms)", "frames": "Trames",
            "channels": "Canaux recus", "missing": "Canaux manquants", "rssi": "RSSI moyen",
            "frame_duration": "Duree trame (us)", "event_span": "Duree evenement (ms)",
        }
        widths = {"event": 90, "time": 110, "interval": 130, "frames": 80, "channels": 130, "missing": 150, "rssi": 110, "frame_duration": 140, "event_span": 160}
        for column in columns:
            self.tree.heading(column, text=headings[column])
            self.tree.column(column, width=widths[column], anchor="center")
        scrollbar = ttk.Scrollbar(self.tab_table, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)
        self.tree.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")

    def start_capture(self) -> None:
        if self.running:
            return
        try:
            self.capture.start()
        except Exception as error:
            messagebox.showerror("Erreur de capture", str(error))
            return
        self.running = True
        self.export_done = False
        self.start_button.configure(state="disabled")
        self.stop_button.configure(state="normal")
        self.status_label.configure(text=f"Etat : capture sur {self.capture.interface_name}")

    def stop_capture(self) -> None:
        if not self.running:
            return
        self.capture.stop()
        self.running = False
        self._drain_queues()
        self.start_button.configure(state="normal")
        self.stop_button.configure(state="disabled")
        self.export_report()

    def export_report(self) -> None:
        if not self.events:
            messagebox.showwarning("Aucune donnee", "Aucun evenement n'a encore ete capture.")
            return
        try:
            generated = ReportExporter(self.output_dir, self.frames, self.events).export_all()
            self.export_done = True
            self.status_label.configure(text=f"Etat : sauvegarde terminee | {self.output_dir}")
            messagebox.showinfo("Sauvegarde terminee", f"CSV, statistiques, graphes PNG et rapport PDF enregistres dans :\n\n{self.output_dir}\n\n{len(generated)} fichiers generes.")
        except Exception as error:
            messagebox.showerror("Erreur d'export", str(error))

    def update_ui(self) -> None:
        if self.running:
            self.capture.flush_pending_event()
        changed = self._drain_queues()
        if changed:
            self._update_statistics(); self._update_plots()
        self.root.after(REFRESH_MS, self.update_ui)

    def _drain_queues(self) -> bool:
        changed = False
        while True:
            try:
                self.frames.append(self.capture.frame_queue.get_nowait()); changed = True
            except queue.Empty:
                break
        while True:
            try:
                event = self.capture.event_queue.get_nowait()
                self.events.append(event); self._insert_event_row(event); changed = True
            except queue.Empty:
                break
        return changed

    def _insert_event_row(self, event: AdvertisingEvent) -> None:
        self.tree.insert("", 0, values=(
            event.number, f"{event.relative_s:.3f}", "--" if event.interval_ms is None else f"{event.interval_ms:.2f}",
            event.frame_count, ",".join(map(str, event.channels)) or "--", ",".join(map(str, event.missing_channels)) or "--",
            "--" if event.rssi_mean_dbm is None else f"{event.rssi_mean_dbm:.2f}",
            f"{event.mean_frame_duration_us:.1f}", f"{event.event_span_ms:.3f}",
        ))
        children = self.tree.get_children()
        if len(children) > 500:
            self.tree.delete(children[-1])

    def _update_statistics(self) -> None:
        stats = calculate_statistics(self.frames, self.events)
        a, l, r, i = stats["acquisition"], stats["loss"], stats["rssi_dbm"], stats["event_interval_ms"]
        self.stat_vars["events"].set(f"Evenements : {len(self.events)}")
        self.stat_vars["frames"].set(f"Trames : {len(self.frames)}")
        self.stat_vars["rssi"].set("RSSI moyen : -- dBm" if r["mean"] is None else f"RSSI moyen : {r['mean']:.2f} dBm")
        self.stat_vars["interval"].set("Intervalle : -- ms" if i["mean"] is None else f"Intervalle : {i['mean']:.2f} ms")
        self.stat_vars["complete"].set(f"Complets : {a['complete_event_rate_percent']:.1f} %")
        self.stat_vars["loss"].set(f"Perte evenements : {l['event_loss_rate_percent']:.1f} %")
        self.stat_vars["packet_loss"].set(f"Perte canaux : {l['channel_packet_loss_rate_percent']:.1f} %")

    def _update_plots(self) -> None:
        data = self.events[-MAX_DISPLAY_POINTS:]
        if not data:
            return
        times = [event.relative_s for event in data]
        rssis = [math.nan if event.rssi_mean_dbm is None else event.rssi_mean_dbm for event in data]
        durations = [event.mean_frame_duration_us for event in data]
        intervals = [math.nan if event.interval_ms is None else event.interval_ms for event in data]

        self.ax_rssi.clear(); self.ax_rssi.plot(times, rssis, marker="o", markersize=3)
        self.ax_rssi.set_title("RSSI moyen par evenement"); self.ax_rssi.set_xlabel("Temps relatif (s)"); self.ax_rssi.set_ylabel("RSSI moyen (dBm)"); self.ax_rssi.grid(True)
        self.ax_duration.clear(); self.ax_duration.plot(times, durations, marker="o", markersize=3)
        self.ax_duration.set_title("Duree moyenne des trames"); self.ax_duration.set_xlabel("Temps relatif (s)"); self.ax_duration.set_ylabel("Duree (us)"); self.ax_duration.grid(True)
        self.live_fig.tight_layout(); self.live_canvas.draw_idle()

        self.ax_interval.clear(); self.ax_interval.plot(times, intervals, marker="o", markersize=3)
        self.ax_interval.set_title("Intervalle entre evenements successifs"); self.ax_interval.set_xlabel("Temps relatif (s)"); self.ax_interval.set_ylabel("Intervalle (ms)"); self.ax_interval.grid(True)
        stats = calculate_statistics(self.frames, self.events); loss = stats["loss"]
        self.ax_loss.clear(); self.ax_loss.bar(["Evenements", "Paquets/canaux"], [loss["event_loss_rate_percent"], loss["channel_packet_loss_rate_percent"]])
        self.ax_loss.set_title("Taux de perte estime"); self.ax_loss.set_ylabel("Perte (%)")
        self.interval_fig.tight_layout(); self.interval_canvas.draw_idle()

        self.ax_hist.clear(); valid = [value for value in intervals if not math.isnan(value)]
        if valid:
            self.ax_hist.hist(valid, bins=min(30, max(5, int(math.sqrt(len(valid))))))
        self.ax_hist.set_title("Histogramme des intervalles"); self.ax_hist.set_xlabel("Intervalle (ms)"); self.ax_hist.set_ylabel("Nombre")
        self.ax_channels.clear(); counts = stats["channels"]
        self.ax_channels.bar([37, 38, 39], [counts[37], counts[38], counts[39]])
        self.ax_channels.set_title("Repartition des canaux"); self.ax_channels.set_xlabel("Canal BLE"); self.ax_channels.set_ylabel("Nombre d'evenements"); self.ax_channels.set_xticks([37, 38, 39])
        self.distribution_fig.tight_layout(); self.distribution_canvas.draw_idle()

    def on_close(self) -> None:
        if self.running:
            self.capture.stop(); self.running = False; self._drain_queues()
        if self.events and not self.export_done:
            try:
                ReportExporter(self.output_dir, self.frames, self.events).export_all()
            except Exception:
                pass
        self.root.destroy()


def main() -> None:
    root = tk.Tk()
    IBeaconEventApp(root)
    root.mainloop()


if __name__ == "__main__":
    main()
