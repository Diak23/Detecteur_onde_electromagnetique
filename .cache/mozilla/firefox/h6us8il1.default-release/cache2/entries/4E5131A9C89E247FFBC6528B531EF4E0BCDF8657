@dataclass
class MutableEvent:
    frames: list[BLEFrame] = field(default_factory=list)
    first_wall_time: float = field(default_factory=time.time)

    @property
    def start_timestamp_s(self) -> float:
        return min(frame.timestamp_s for frame in self.frames)

    @property
    def channels(self) -> set[int]:
        return {
            frame.channel
            for frame in self.frames
            if frame.channel in {37, 38, 39}
        }


class EventGrouper:
    def __init__(self, window_ms: float) -> None:
        self.window_ms = window_ms
        self.current: Optional[MutableEvent] = None
        self.last_event_start: Optional[float] = None
        self.event_number = 0
        self.lock = threading.Lock()

    def add_frame(self, frame: BLEFrame) -> Optional[AdvertisingEvent]:
        with self.lock:
            if self.current is None:
                self.current = MutableEvent(frames=[frame])
                return None

            delta_ms = (frame.timestamp_s - self.current.start_timestamp_s) * 1000.0
            same_channel = frame.channel is not None and frame.channel in self.current.channels
            same_payload = self._same_payload(self.current.frames[0], frame)

            belongs = (
                0.0 <= delta_ms <= self.window_ms
                and same_payload
                and not same_channel
                and len(self.current.frames) < 3
            )

            if belongs:
                self.current.frames.append(frame)
                if self.current.channels == {37, 38, 39}:
                    return self._finalize_locked()
                return None

            completed = self._finalize_locked()
            self.current = MutableEvent(frames=[frame])
            return completed

    def flush_if_expired(self) -> Optional[AdvertisingEvent]:
        with self.lock:
            if self.current is None:
                return None
            elapsed_ms = (time.time() - self.current.first_wall_time) * 1000.0
            if elapsed_ms >= self.window_ms:
                return self._finalize_locked()
            return None

    def flush(self) -> Optional[AdvertisingEvent]:
        with self.lock:
            if self.current is None:
                return None
            return self._finalize_locked()

    @staticmethod
    def _same_payload(first: BLEFrame, second: BLEFrame) -> bool:
        if first.raw_data and second.raw_data:
            return first.raw_data == second.raw_data
        return (
            first.mac.lower() == second.mac.lower()
            and first.payload_length == second.payload_length
            and first.company_id == second.company_id
            and first.pdu_type == second.pdu_type
        )

    def _finalize_locked(self) -> AdvertisingEvent:
        assert self.current is not None
        frames = sorted(self.current.frames, key=lambda item: item.timestamp_s)
        self.event_number += 1

        start_s = min(frame.timestamp_s for frame in frames)
        end_s = max(frame.end_timestamp_s for frame in frames)
        interval_ms = None
        if self.last_event_start is not None:
            interval_ms = (start_s - self.last_event_start) * 1000.0
        self.last_event_start = start_s

        channels = sorted({frame.channel for frame in frames if frame.channel in {37, 38, 39}})
        missing = sorted({37, 38, 39} - set(channels))
        rssis = [frame.rssi_dbm for frame in frames if frame.rssi_dbm is not None]
        durations = [frame.duration_us for frame in frames]
        lengths = [frame.payload_length for frame in frames]

        event = AdvertisingEvent(
            number=self.event_number,
            start_timestamp_s=start_s,
            end_timestamp_s=end_s,
            relative_s=frames[0].relative_s,
            interval_ms=interval_ms,
            frame_count=len(frames),
            channels=channels,
            missing_channels=missing,
            rssi_mean_dbm=statistics.fmean(rssis) if rssis else None,
            rssi_min_dbm=min(rssis) if rssis else None,
            rssi_max_dbm=max(rssis) if rssis else None,
            mean_frame_duration_us=statistics.fmean(durations),
            total_radio_duration_us=sum(durations),
            event_span_ms=(end_s - start_s) * 1000.0,
            payload_length_mean=statistics.fmean(lengths),
            pdu_types=sorted({frame.pdu_type for frame in frames}),
            company_id=frames[0].company_id,
            raw_data=frames[0].raw_data,
        )
        self.current = None
        return event


class BLECapture:
    def __init__(self, target_mac: str, output_dir: Path) -> None:
        self.target_mac = target_mac.lower()
        self.output_dir = output_dir
        self.raw_csv_path = output_dir / "trames_brutes.csv"
        self.events_csv_path = output_dir / "evenements_advertising.csv"
        self.process: Optional[subprocess.Popen[str]] = None
        self.thread: Optional[threading.Thread] = None
        self.running = False
        self.frame_queue: queue.Queue[BLEFrame] = queue.Queue()
        self.event_queue: queue.Queue[AdvertisingEvent] = queue.Queue()
        self.frame_count = 0
        self.first_timestamp: Optional[float] = None
        self.interface_name: Optional[str] = None
        self.grouper = EventGrouper(EVENT_GROUP_WINDOW_MS)

    @staticmethod
    def find_sniffer_interface() -> Optional[str]:
        try:
            result = subprocess.run(["tshark", "-D"], check=True, capture_output=True, text=True)
        except (subprocess.CalledProcessError, FileNotFoundError):
            return None

        preferred, fallback = [], []
        for line in result.stdout.splitlines():
            match = re.match(r"^\d+\.\s+(.+?)(?:\s+\(|$)", line.strip())
            if not match:
                continue
            interface = match.group(1).strip()
            lower = line.lower()
            if "nrf sniffer" in lower or "nrf_sniffer" in lower:
                preferred.append(interface)
            elif "/dev/ttyusb" in lower or "/dev/ttyacm" in lower:
                fallback.append(interface)
        return preferred[0] if preferred else (fallback[0] if fallback else None)

    def _build_command(self) -> list[str]:
        if not self.interface_name:
            raise RuntimeError("Interface nRF Sniffer non definie.")
        command = [
            "tshark", "-l", "-n", "-i", self.interface_name,
            "-Y", "btle", "-T", "fields",
            "-E", "separator=;", "-E", "occurrence=f", "-E", "quote=n",
        ]
        for field_name in TSHARK_FIELDS:
            command.extend(["-e", field_name])
        return command

    def start(self) -> None:
        if self.running:
            return
        self.interface_name = self.find_sniffer_interface()
        if not self.interface_name:
            raise RuntimeError("Aucune interface nRF Sniffer detectee. Execute : tshark -D")

        self.output_dir.mkdir(parents=True, exist_ok=True)
        self._initialize_csv_files()
        self.process = subprocess.Popen(
            self._build_command(), stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            text=True, bufsize=1,
        )
        self.running = True
        self.thread = threading.Thread(target=self._read_loop, daemon=True)
        self.thread.start()

    def stop(self) -> None:
        self.running = False
        if self.process and self.process.poll() is None:
            self.process.send_signal(signal.SIGINT)
            try:
                self.process.wait(timeout=3)
            except subprocess.TimeoutExpired:
                self.process.terminate()
        last_event = self.grouper.flush()
        if last_event is not None:
            self._save_event(last_event)
            self.event_queue.put(last_event)
        self.process = None

    def flush_pending_event(self) -> None:
        event = self.grouper.flush_if_expired()
        if event is not None:
            self._save_event(event)
            self.event_queue.put(event)

    def _initialize_csv_files(self) -> None:
        with self.raw_csv_path.open("w", newline="", encoding="utf-8") as file:
            csv.writer(file, delimiter=";").writerow([
                "numero", "timestamp_s", "temps_relatif_s", "mac",
                "longueur_payload_octets", "type_pdu", "rssi_dbm", "canal",
                "duree_estimee_us", "timestamp_fin_s", "company_id", "donnees_brutes",
            ])
        with self.events_csv_path.open("w", newline="", encoding="utf-8") as file:
            csv.writer(file, delimiter=";").writerow([
                "numero_evenement", "timestamp_debut_s", "timestamp_fin_s",
                "temps_relatif_s", "intervalle_evenements_ms", "nombre_trames",
                "canaux_recus", "canaux_manquants", "rssi_moyen_dbm", "rssi_min_dbm",
                "rssi_max_dbm", "duree_moyenne_trame_us", "duree_radio_totale_us",
                "duree_evenement_ms", "longueur_payload_moyenne", "types_pdu",
                "company_id", "donnees_brutes", "uuid_cible", "major_cible", "minor_cible",
            ])

    @staticmethod
    def _safe_int(value: str) -> Optional[int]:
        if not value:
            return None
        try:
            return int(value, 16) if value.lower().startswith("0x") else int(float(value))
        except ValueError:
            return None

    @staticmethod
    def _duration_le1m_us(payload_length: int) -> float:
        return float((10 + payload_length) * 8)

    def _read_loop(self) -> None:
        assert self.process is not None and self.process.stdout is not None
        for raw_line in self.process.stdout:
            if not self.running:
                break
            line = raw_line.strip()
            if not line:
                continue
            parts = line.split(";")
            parts += [""] * (len(TSHARK_FIELDS) - len(parts))
            time_epoch, mac, length, pdu_type, rssi, channel, company_id, raw_data = parts[:len(TSHARK_FIELDS)]
            if not time_epoch or not mac or mac.lower().strip() != self.target_mac:
                continue
            try:
                timestamp_s = float(time_epoch)
            except ValueError:
                continue

            payload_length = self._safe_int(length) or 0
            rssi_dbm = self._safe_int(rssi)
            channel_value = self._safe_int(channel)
            if self.first_timestamp is None:
                self.first_timestamp = timestamp_s
            self.frame_count += 1
            duration_us = self._duration_le1m_us(payload_length)

            frame = BLEFrame(
                self.frame_count, timestamp_s, timestamp_s - self.first_timestamp,
                mac, payload_length, pdu_type or "Inconnu", rssi_dbm, channel_value,
                duration_us, timestamp_s + duration_us / 1_000_000.0,
                company_id, raw_data,
            )
            self._save_raw_frame(frame)
            self.frame_queue.put(frame)
            completed = self.grouper.add_frame(frame)
            if completed is not None:
                self._save_event(completed)
                self.event_queue.put(completed)

    def _save_raw_frame(self, frame: BLEFrame) -> None:
        with self.raw_csv_path.open("a", newline="", encoding="utf-8") as file:
            csv.writer(file, delimiter=";").writerow([
                frame.number, f"{frame.timestamp_s:.9f}", f"{frame.relative_s:.6f}",
                frame.mac, frame.payload_length, frame.pdu_type,
                "" if frame.rssi_dbm is None else frame.rssi_dbm,
                "" if frame.channel is None else frame.channel,
                f"{frame.duration_us:.3f}", f"{frame.end_timestamp_s:.9f}",
                frame.company_id, frame.raw_data,
            ])

    def _save_event(self, event: AdvertisingEvent) -> None:
        with self.events_csv_path.open("a", newline="", encoding="utf-8") as file:
            csv.writer(file, delimiter=";").writerow([
                event.number, f"{event.start_timestamp_s:.9f}", f"{event.end_timestamp_s:.9f}",
                f"{event.relative_s:.6f}", "" if event.interval_ms is None else f"{event.interval_ms:.3f}",
                event.frame_count, ",".join(map(str, event.channels)),
                ",".join(map(str, event.missing_channels)),
                "" if event.rssi_mean_dbm is None else f"{event.rssi_mean_dbm:.3f}",
                "" if event.rssi_min_dbm is None else event.rssi_min_dbm,
                "" if event.rssi_max_dbm is None else event.rssi_max_dbm,
                f"{event.mean_frame_duration_us:.3f}", f"{event.total_radio_duration_us:.3f}",
                f"{event.event_span_ms:.3f}", f"{event.payload_length_mean:.3f}",
                ",".join(event.pdu_types), event.company_id, event.raw_data,
                TARGET_UUID, TARGET_MAJOR, TARGET_MINOR,
            ])


def describe(values: list[float]) -> dict:
    if not values:
        return {"count": 0, "mean": None, "median": None, "minimum": None, "maximum": None, "stdev": None}
    return {
        "count": len(values), "mean": statistics.fmean(values),
        "median": statistics.median(values), "minimum": min(values), "maximum": max(values),
        "stdev": statistics.stdev(values) if len(values) >= 2 else 0.0,
    }


def calculate_statistics(frames: list[BLEFrame], events: list[AdvertisingEvent]) -> dict:
    rssis = [event.rssi_mean_dbm for event in events if event.rssi_mean_dbm is not None]
    intervals = [event.interval_ms for event in events if event.interval_ms is not None and event.interval_ms > EVENT_GROUP_WINDOW_MS]
    frame_durations = [event.mean_frame_duration_us for event in events]
    event_spans = [event.event_span_ms for event in events]

    nominal = statistics.median(intervals) if intervals else None
    missing_events = 0
    if nominal and nominal > 0:
        for interval in intervals:
            if interval / nominal >= 1.5:
                missing_events += max(0, round(interval / nominal) - 1)

    transitions = len(intervals) + missing_events
    event_loss = 100.0 * missing_events / transitions if transitions else 0.0
    expected_packets = len(events) * 3
    observed_packets = sum(len(event.channels) for event in events)
    missing_packets = max(0, expected_packets - observed_packets)
    packet_loss = 100.0 * missing_packets / expected_packets if expected_packets else 0.0
    complete_events = sum(set(event.channels) == {37, 38, 39} for event in events)
    duration_s = events[-1].start_timestamp_s - events[0].start_timestamp_s if events else 0.0

    return {
        "target": {"mac": TARGET_MAC.upper(), "uuid": TARGET_UUID, "major": TARGET_MAJOR, "minor": TARGET_MINOR},
        "configuration": {"event_group_window_ms": EVENT_GROUP_WINDOW_MS},
        "acquisition": {
            "raw_frame_count": len(frames), "event_count": len(events),
            "complete_event_count": complete_events,
            "complete_event_rate_percent": 100.0 * complete_events / len(events) if events else 0.0,
            "duration_s": duration_s,
        },
        "rssi_dbm": describe(rssis),
        "event_interval_ms": describe(intervals),
        "mean_frame_duration_us": describe(frame_durations),
        "event_span_ms": describe(event_spans),
        "loss": {
            "nominal_interval_ms": nominal, "estimated_missing_events": missing_events,
            "event_loss_rate_percent": event_loss,
            "expected_channel_packets": expected_packets,
            "observed_unique_channel_packets": observed_packets,
            "missing_channel_packets": missing_packets,
            "channel_packet_loss_rate_percent": packet_loss,
        },
        "channels": {channel: sum(channel in event.channels for event in events) for channel in (37, 38, 39)},
    }


class ReportExporter:
    def __init__(self, output_dir: Path, frames: list[BLEFrame], events: list[AdvertisingEvent]) -> None:
        self.output_dir = output_dir
        self.frames = frames
        self.events = events
        self.stats = calculate_statistics(frames, events)

    def export_all(self) -> list[Path]:
        generated = self._save_statistics()
        generated.extend(self._save_graphs())
        generated.append(self._save_pdf_report())
        return generated

    def _save_statistics(self) -> list[Path]:
        json_path = self.output_dir / "statistiques.json"
        txt_path = self.output_dir / "rapport_statistiques.txt"
        json_path.write_text(json.dumps(self.stats, indent=2, ensure_ascii=False), encoding="utf-8")
        a, l, r, i = self.stats["acquisition"], self.stats["loss"], self.stats["rssi_dbm"], self.stats["event_interval_ms"]
        fmt = lambda value: "--" if value is None else f"{value:.3f}"
        text = f"""RAPPORT STATISTIQUE - IBEACON RASPBERRY PI
================================================

MAC : {TARGET_MAC.upper()}
UUID : {TARGET_UUID}
Major : {TARGET_MAJOR}
Minor : {TARGET_MINOR}

Trames brutes : {a['raw_frame_count']}
Evenements regroupes : {a['event_count']}
Evenements complets 37/38/39 : {a['complete_event_count']}
Taux d'evenements complets : {a['complete_event_rate_percent']:.2f} %
Duree acquisition : {a['duration_s']:.3f} s

RSSI moyen : {fmt(r['mean'])} dBm
RSSI median : {fmt(r['median'])} dBm
Intervalle moyen : {fmt(i['mean'])} ms
Intervalle median : {fmt(i['median'])} ms
Intervalle nominal estime : {fmt(l['nominal_interval_ms'])} ms

Evenements manquants estimes : {l['estimated_missing_events']}
Taux de perte d'evenements : {l['event_loss_rate_percent']:.2f} %
Taux de perte paquets/canaux : {l['channel_packet_loss_rate_percent']:.2f} %

Canal 37 : {self.stats['channels'][37]}
Canal 38 : {self.stats['channels'][38]}
Canal 39 : {self.stats['channels'][39]}

Methode : regroupement des paquets 37/38/39 portant les memes donnees dans une fenetre de {EVENT_GROUP_WINDOW_MS:.1f} ms.
"""
        txt_path.write_text(text, encoding="utf-8")
        return [json_path, txt_path]

    def _save_graphs(self) -> list[Path]:
        paths = []
        times = [event.relative_s for event in self.events]
        rssis = [math.nan if event.rssi_mean_dbm is None else event.rssi_mean_dbm for event in self.events]
        intervals = [math.nan if event.interval_ms is None else event.interval_ms for event in self.events]
        durations = [event.mean_frame_duration_us for event in self.events]
        spans = [event.event_span_ms for event in self.events]

        specs = [
            ("01_rssi_evenements.png", "RSSI moyen par evenement", "RSSI moyen (dBm)", rssis),
            ("02_intervalles_evenements.png", "Intervalle entre evenements successifs", "Intervalle (ms)", intervals),
            ("03_duree_trames.png", "Duree moyenne des trames", "Duree (us)", durations),
            ("04_duree_evenements.png", "Duree totale observee des evenements", "Duree evenement (ms)", spans),
        ]
        for filename, title, ylabel, values in specs:
            fig = Figure(figsize=(10, 5), dpi=150)
            ax = fig.add_subplot(111)
            ax.plot(times, values, marker="o", markersize=3)
            ax.set_title(title)
            ax.set_xlabel("Temps relatif (s)")
            ax.set_ylabel(ylabel)
            ax.grid(True)
            fig.tight_layout()
            path = self.output_dir / filename
            fig.savefig(path)
            paths.append(path)

        fig = Figure(figsize=(8, 5), dpi=150)
        ax = fig.add_subplot(111)
        ax.bar([37, 38, 39], [self.stats["channels"][37], self.stats["channels"][38], self.stats["channels"][39]])
        ax.set_title("Repartition des canaux")
        ax.set_xlabel("Canal BLE")
        ax.set_ylabel("Nombre d'evenements")
        ax.set_xticks([37, 38, 39])
        fig.tight_layout()
        path = self.output_dir / "05_repartition_canaux.png"
        fig.savefig(path)
        paths.append(path)

        valid_intervals = [value for value in intervals if not math.isnan(value)]
        fig = Figure(figsize=(8, 5), dpi=150)
        ax = fig.add_subplot(111)
        if valid_intervals:
            ax.hist(valid_intervals, bins=min(30, max(5, int(math.sqrt(len(valid_intervals))))))
        ax.set_title("Histogramme des intervalles")
        ax.set_xlabel("Intervalle (ms)")
        ax.set_ylabel("Nombre d'evenements")
        fig.tight_layout()
        path = self.output_dir / "06_histogramme_intervalles.png"
        fig.savefig(path)
        paths.append(path)

        fig = Figure(figsize=(8, 5), dpi=150)
        ax = fig.add_subplot(111)
        loss = self.stats["loss"]
        ax.bar(["Evenements", "Paquets/canaux"], [loss["event_loss_rate_percent"], loss["channel_packet_loss_rate_percent"]])
        ax.set_title("Taux de perte estime")
        ax.set_ylabel("Perte (%)")
        fig.tight_layout()
        path = self.output_dir / "07_taux_perte.png"
        fig.savefig(path)
        paths.append(path)
        return paths

    def _save_pdf_report(self) -> Path:
        pdf_path = self.output_dir / "rapport_ibeacon.pdf"
        with PdfPages(pdf_path) as pdf:
            fig = Figure(figsize=(8.27, 11.69), dpi=120)
            ax = fig.add_subplot(111)
            ax.axis("off")
            a, l, r, i = self.stats["acquisition"], self.stats["loss"], self.stats["rssi_dbm"], self.stats["event_interval_ms"]
            fmt = lambda value: "--" if value is None else f"{value:.2f}"
            summary = (
                "RAPPORT D'ACQUISITION IBEACON\n\n"
                f"MAC : {TARGET_MAC.upper()}\nUUID : {TARGET_UUID}\nMajor : {TARGET_MAJOR} | Minor : {TARGET_MINOR}\n\n"
                f"Trames brutes : {a['raw_frame_count']}\nEvenements regroupes : {a['event_count']}\n"
                f"Evenements complets : {a['complete_event_count']} ({a['complete_event_rate_percent']:.2f} %)\n\n"
                f"RSSI moyen : {fmt(r['mean'])} dBm\nIntervalle moyen : {fmt(i['mean'])} ms\n"
                f"Intervalle median : {fmt(i['median'])} ms\nIntervalle nominal estime : {fmt(l['nominal_interval_ms'])} ms\n\n"
                f"Evenements manquants estimes : {l['estimated_missing_events']}\n"
                f"Taux de perte d'evenements : {l['event_loss_rate_percent']:.2f} %\n"
                f"Taux de perte paquets/canaux : {l['channel_packet_loss_rate_percent']:.2f} %\n\n"
                f"Methode : regroupement 37/38/39 dans une fenetre de {EVENT_GROUP_WINDOW_MS:.1f} ms."
            )
            ax.text(0.05, 0.95, summary, va="top", ha="left", fontsize=11, transform=ax.transAxes)
            pdf.savefig(fig)

